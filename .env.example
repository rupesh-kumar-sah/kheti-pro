# ===== Required for production =====

# PostgreSQL connection string
# Get a free database from https://neon.tech (recommended for Render free tier)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random 48+ character string used to sign auth tokens
# Generate one with: openssl rand -hex 48
SESSION_SECRET=change-me-to-a-long-random-string

# Google Gemini API key
# Get a free key at https://aistudio.google.com/app/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key-here

# ===== Optional =====

# Comma-separated list of allowed origins for CORS in production.
# Leave empty to allow same-origin requests only.
# Example: ALLOWED_ORIGINS=https://khetismart.com,https://www.khetismart.com
ALLOWED_ORIGINS=

# Port the server listens on (Render sets this automatically — leave unset)
# PORT=3001
