# ===== Required for AI Features =====

# Groq API Key (Currently used for chat, guides, and analysis)
# Get a free key at https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini API key (Alternative/Backup)
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===== Required for Database & Auth =====

# PostgreSQL connection string
# Get a free database from https://neon.tech (recommended for Render free tier)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random 48+ character string used to sign auth tokens
# Generate one with: openssl rand -hex 48
SESSION_SECRET=change-me-to-a-long-random-string

# ===== Optional =====

# Comma-separated list of allowed origins for CORS in production.
# Leave empty to allow same-origin requests only.
ALLOWED_ORIGINS=

# Port the server listens on (Render sets this automatically)
# PORT=3001

